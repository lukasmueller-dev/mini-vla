{
  "name": "mini-vla",
  "version": "0.1.0",
  "description": "Standalone in-browser vision-language-action demo: a TensorFlow.js behavior-cloning policy (action + color + gripper + spatial-attention heads) trained live against an analytical-IK expert, with a policy-rollout engine and two canvas renderers.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    "./trainer": "./src/trainer.ts",
    "./trainer.core": "./src/trainer.core.ts",
    "./rollout": "./src/rollout.ts",
    "./scene": "./src/scene.ts",
    "./task": "./src/task.ts",
    "./geometry": "./src/geometry.ts",
    "./config": "./src/config-public.ts",
    "./model": "./src/model.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "assets"
  ],
  "scripts": {
    "demo": "vite demo",
    "build:demo": "vite build demo",
    "eval": "node eval/run.mjs",
    "typecheck": "tsc --noEmit",
    "gen:embeddings": "node scripts/gen-embeddings-data.mjs"
  },
  "peerDependencies": {
    "@tensorflow/tfjs": "^4.22.0"
  },
  "devDependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "playwright": "^1.49.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.0"
  }
}
